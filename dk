            target_date = datetime.now().replace(tzinfo=None).date()

            # Ускорение: заранее строим индекс "нормализованный номер ЗНО на пополнение ПФ" ->
            # ПЕРВЫЙ индекс строки. Раньше для каждой строки избытка выполнялось полное
            # сканирование df (O(n^2) и трижды продублировано) — теперь это O(1)-поиск.
            first_idx_by_zno = {}
            if 'ЗНО на пополнение ПФ' in df.columns:
                for _i, _v in df['ЗНО на пополнение ПФ'].astype(str).str.strip().items():
                    if _v not in first_idx_by_zno:
                        first_idx_by_zno[_v] = _i

            # Заголовок для главных показателей
            dashboard_ws[f'A{row}'] = '✅ Главные показатели'
            dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=14, bold=True, color='26c6da')
            row += 1
            
            # Заголовки столбцов
            dashboard_ws[f'A{row}'] = 'Показатель'
            dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=11, bold=True, color='333333')
            dashboard_ws[f'B{row}'] = 'Значение'
            dashboard_ws[f'B{row}'].font = openpyxl.styles.Font(size=11, bold=True, color='333333')
            dashboard_ws[f'C{row}'] = 'Описание'
            dashboard_ws[f'C{row}'].font = openpyxl.styles.Font(size=11, bold=True, color='333333')
            row += 1
            
            # Вычисляем показатели
            # 1. ЗНО в работе
            df_inwork = df[(df['ЗНО на Техрефреш'].notna()) & (df['ЗНО на Техрефреш'].astype(str).str.strip() != '-')]
            zno_inwork = len(df_inwork[df_inwork['ЗНО на Техрефреш: статус'].astype(str).str.contains('В работе', na=False)])
            
            # 2. Готовы к выставлению
            # ПФ пополнен = 1 И ЗНО на Техрефреш пустой или "-"
            def is_zno_empty(val):
                if pd.isna(val): return True
                return str(val).strip() in ['', '-']
            
            # Проверяем ПФ пополнен (может быть 1, "1", 1.0, "1 ")
            pf_populated_mask = (
                (df['ПФ пополнен'] == 1) |
                (df['ПФ пополнен'].astype(str).str.strip() == '1') |
                (df['ПФ пополнен'].astype(float) == 1.0)
            )
            
            # Проверяем ЗНО на Техрефреш (пустой или "-")
            zno_empty_mask = df['ЗНО на Техрефреш'].apply(is_zno_empty)
            
            df_ready = df[pf_populated_mask & zno_empty_mask]
            ready_count = len(df_ready)
            
            # 3. Избыток по подменным фондам
            # Данные считаем здесь (нужны для блока "Главные показатели"),
            # а детальную таблицу выводим внизу листа — под блоком
            # "Недельная динамика по типам техрефреша".

            # Подготовка данных по избытку для подменных фондов
            # Используем те же критерии, что и для общего показателя
            # 1. Наличие "ИЗБЫТОК" в логе
            # 2. ПФ пополнен = 1
            # 3. Дата исполнения ЗНО на пополнение ПФ >= 2 месяцев от текущей даты
            
            excess_replacements = []
            
            if 'Log' in df.columns:
                # Сначала находим все записи с ИЗБЫТОК
                df_excess_temp = df[df['Log'].astype(str).str.contains('ИЗБЫТОК', na=False, case=False)]
                
                # Фильтруем по ПФ пополнен = 1
                for idx, row_data in df_excess_temp.iterrows():
                    pf_pop = row_data.get('ПФ пополнен', '')
                    
                    is_pf_populated = False
                    try:
                        if pd.isna(pf_pop):
                            is_pf_populated = False
                        elif pf_pop == 1:
                            is_pf_populated = True
                        elif str(pf_pop).strip() == '1':
                            is_pf_populated = True
                        elif float(pf_pop) == 1.0:
                            is_pf_populated = True
                    except:
                        pass
                    
                    if is_pf_populated:
                        pf_name = str(row_data.get('Адрес ПФ', '')).strip() if pd.notna(row_data.get('Адрес ПФ', '')) else '-'
                        tech_type = str(row_data.get('Тип', '')).strip() if pd.notna(row_data.get('Тип', '')) else '-'
                        
                        # Проверяем дату исполнения ЗНО на пополнение ПФ
                        # Приоритет 1: ЗНО на пополнение ПФ: дата исполнения (если номер ЗНО >= 13 символов)
                        # Приоритет 2: ЗНО на пополнение ПФ: дата создания (если номер ЗНО >= 13 символов)
                        # Приоритет 3: Доп. параметр 2 (номер ЗНО) -> поиск даты в столбце "ЗНО на пополнение ПФ"
                        date_col_replenishment = 'ЗНО на пополнение ПФ: дата исполнения'
                        replenishment_date = None
                        
                        # Получаем номер ЗНО из основного поля
                        refusal_zno_field = row_data.get('ЗНО на пополнение ПФ', '')
                        zno_from_field = str(refusal_zno_field).strip() if pd.notna(refusal_zno_field) else ''
                        
                        # Получаем номер из Доп. параметр 2
                        zno_ref = str(row_data.get('Доп. параметр 2', '')).strip() if pd.notna(row_data.get('Доп. параметр 2', '')) else ''
                        
                        correct_zno = ''  # Корректный номер ЗНО (13+ символов)
                        
                        # Приоритет 1: Проверяем ЗНО из основного поля
                        if len(zno_from_field) >= 13:
                            correct_zno = zno_from_field
                            # Ищем строку с этим ЗНО в столбце "ЗНО на пополнение ПФ"
                            matching_idx = first_idx_by_zno.get(correct_zno)
                            if matching_idx is not None:
                                replenishment_date = df.loc[matching_idx, date_col_replenishment]
                        
                        # Приоритет 2: Проверяем ЗНО из Доп. параметр 2, если не нашли дату
                        if replenishment_date is None and len(zno_ref) >= 13:
                            correct_zno = zno_ref
                            # Ищем этот номер в столбце "ЗНО на пополнение ПФ"
                            matching_idx = first_idx_by_zno.get(correct_zno)
                            if matching_idx is not None:
                                replenishment_date = df.loc[matching_idx, date_col_replenishment]
                                
                                # Если дата исполнения не найдена, проверяем дату создания
                                if pd.isna(replenishment_date):
                                    date_col_create = 'ЗНО на пополнение ПФ: дата создания'
                                    if date_col_create in df.columns:
                                        replenishment_date = df.loc[matching_idx, date_col_create]
                        
                        # Проверяем найденную дату
                        is_valid_date = False  # По умолчанию не валидна
                        is_found_date = False  # Флаг - дата была найдена
                        
                        if pd.notna(replenishment_date):
                            replenishment_dt = pd.to_datetime(replenishment_date, errors='coerce').replace(tzinfo=None)
                            if hasattr(replenishment_dt, 'date'):
                                is_found_date = True
                                replenishment_date_only = replenishment_dt.date()
                                # Рассчитываем дату 2 месяцев назад от текущей даты
                                two_months_ago = target_date - timedelta(days=60)
                                # Оставляем только если дата >= 2 месяцев назад от текущей даты
                                # Это означает, что ЗНО на пополнение ПФ был выполнен своевременно
                                # Но замена для отказника не найдена → реальный избыток
                                if replenishment_date_only >= two_months_ago:
                                    is_valid_date = True
                        
                        # Если дата не найдена - запись не должна попадать в избыток
                        if not is_found_date:
                            continue
                        
                        if is_valid_date:
                            excess_replacements.append({
                                'ПФ': pf_name,
                                'Тип': tech_type,
                                'Серийный номер': str(row_data.get('Серийный номер', '')).strip() if pd.notna(row_data.get('Серийный номер', '')) else '-'
                            })
            
            # Детальная таблица избытка выводится внизу листа (после недельной динамики).
            # Здесь считаем только показатель для блока "Главные показатели".
            excess_count = len(excess_replacements)

            # 4. Процент успешного техрефреша
            df_closed = df[(df['ЗНО на Техрефреш'].notna()) & (df['ЗНО на Техрефреш'].astype(str).str.strip() != '-')]
            # Проверяем, содержит ли результат начальные цифры и точку, затем 1.1 или 1.2
            success_count = len(df_closed[
                df_closed['Результат Техрефреш: группировка'].astype(str).str.contains(r'^(\d+\.\d+\.?\s*)?(1\.1|1\.2)', na=False, case=False, regex=True)
            ])
            success_rate = round((success_count / len(df_closed) * 100) if len(df_closed) > 0 else 0, 1)
            
            # 5. Среднее время закрытия
