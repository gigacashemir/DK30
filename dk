                ('4. Успешный техрефреш (1.1, 1.2)', f"{success_count} ({success_rate}%)", 'Процент группировок 1.1. и 1.2.'),
                ('5. Среднее время закрытия ЗНО', f"{avg_days} дней", 'Среднее количество дней на закрытие ЗНО'),
                ('6. Выполнение плана по активностям', '-', 'См. лист "Выполнение плана"'),
            ]
            
            for metric_name, metric_value, metric_desc in metrics:
                dashboard_ws[f'A{row}'] = metric_name
                dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=10)
                dashboard_ws[f'B{row}'] = metric_value
                dashboard_ws[f'B{row}'].font = openpyxl.styles.Font(size=10, bold=True, color='4a90e2')
                dashboard_ws[f'C{row}'] = metric_desc
                dashboard_ws[f'C{row}'].font = openpyxl.styles.Font(size=9, color='666666')
                row += 1
            
            # Добавляем таблицу выполнения плана на лист Дашборд (сразу после строки "6. Выполнение плана по активностям")
            dashboard_ws[f'A{row}'] = '📋 Выполнение плана по активностям'
            dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=12, bold=True, color='333333')
            row += 1
            
            dashboard_ws[f'A{row}'] = 'Активность'
            dashboard_ws[f'B{row}'] = 'Всего в плане'
            dashboard_ws[f'C{row}'] = 'Выполнено (есть ЗНО)'
            dashboard_ws[f'D{row}'] = 'Процент'
            dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=10, bold=True)
            dashboard_ws[f'B{row}'].font = openpyxl.styles.Font(size=10, bold=True)
            dashboard_ws[f'C{row}'].font = openpyxl.styles.Font(size=10, bold=True)
            dashboard_ws[f'D{row}'].font = openpyxl.styles.Font(size=10, bold=True)
            row += 1
            
            df_with_domain = df[df['Домен'].notna() & (df['Домен'].astype(str).str.strip() != '') & (df['Домен'].astype(str).str.strip() != '-')].copy()
            domain_plan = {}
            for idx, row_data in df_with_domain.iterrows():
                domains = str(row_data.get('Домен', '')).strip()
                if pd.notna(domains) and domains:
                    for d in domains.split(','):
                        domain = d.strip()
                        if domain:
                            if domain not in domain_plan:
                                domain_plan[domain] = {'total': 0, 'completed': 0}
                            domain_plan[domain]['total'] += 1
                            zno = row_data.get('ЗНО на Техрефреш', '')
                            if pd.notna(zno) and str(zno).strip() != '-':
                                domain_plan[domain]['completed'] += 1
            
            for domain, data in sorted(domain_plan.items()):
                dashboard_ws[f'A{row}'] = domain
                dashboard_ws[f'B{row}'] = data['total']
                dashboard_ws[f'C{row}'] = data['completed']
                pct = round(data['completed'] / data['total'] * 100, 1) if data['total'] > 0 else 0
                dashboard_ws[f'D{row}'] = f"{pct}%"
                if pct >= 80:
                    dashboard_ws[f'D{row}'].font = openpyxl.styles.Font(size=10, color='50c878', bold=True)
                elif pct >= 50:
                    dashboard_ws[f'D{row}'].font = openpyxl.styles.Font(size=10, color='f2d94a', bold=True)
                else:
                    dashboard_ws[f'D{row}'].font = openpyxl.styles.Font(size=10, color='e24a33', bold=True)
                row += 1
            
            row += 1  # Пустая строка перед диаграммами
            
            # 1. Распределение по типам оборудования (Круговая диаграмма)
            type_counts = df['Тип'].value_counts()
            
            # Записываем данные в столбцах A-B, диаграмма будет в столбце D
            dashboard_ws[f'A{row}'] = 'Распределение по типам оборудования'
            dashboard_ws[f'A{row}'].font = openpyxl.styles.Font(size=12, bold=True)
