            df_closed_with_dates['created'] = pd.to_datetime(df_closed_with_dates['ЗНО на Техрефреш: дата создания'], errors='coerce').dt.tz_localize(None)
            df_closed_with_dates['closed'] = pd.to_datetime(df_closed_with_dates['ЗНО на Техрефреш: дата исполнения'], errors='coerce').dt.tz_localize(None)
            df_closed_with_dates['days'] = (df_closed_with_dates['closed'] - df_closed_with_dates['created']).dt.days
            avg_days = round(df_closed_with_dates['days'].dropna().mean(), 1) if len(df_closed_with_dates['days'].dropna()) > 0 else 0
            
            # 6. Процент выполнения плана по активностям
            # (Прежний O(n^2)-расчёт domain_plan здесь удалён: он каждую строку искал
