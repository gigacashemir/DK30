            pie.set_categories(labels)
            pie.title = "По типам оборудования"
            pie.height = 12
            pie.width = 12
            
            # Добавляем метки данных
            pie.datalabels = DataLabelList()
            pie.datalabels.showVal = True
            pie.datalabels.showPercent = True
            pie.datalabels.showLeaderLines = True
            
            # Размещаем диаграмму со строки M34
            dashboard_ws.add_chart(pie, "M34")
            row = row + len(type_counts) + 2  # Переходим после данных в столбце A-B
            
