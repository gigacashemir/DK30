                dashboard_ws[f'B{row + i}'] = count
            
            # Создаем круговую диаграмму - размещаем со строки M34 (Диаграмма "По типам оборудования")
            pie = PieChart()
            labels = Reference(dashboard_ws, min_col=1, min_row=row, max_row=row + len(type_counts) - 1)
            data = Reference(dashboard_ws, min_col=2, min_row=row - 1, max_row=row + len(type_counts) - 1)
