    def safe_float(self, val):
        try:
            s = str(val).strip()
            s = re.sub(r'[^\d.,]', '', s)
            s = s.replace(',', '.')
            if s == '': return 0.0
            return float(s)
        except: return 0.0

    def get_previous_working_day(self, ref_date, holidays_list=None):
        """Возвращает последний рабочий день строго РАНЬШЕ ref_date.

        Учитывает выходные (сб, вс) и переданный список праздников holidays_list
        (список объектов datetime.date). Использует только numpy (входит в Anaconda).

        Примеры:
        - ref_date = понедельник, праздников нет -> пятница;
        - ref_date = понедельник, пятница праздник -> четверг;
        - ref_date = понедельник, чт+пт праздники -> среда.
        """
        # numpy busday: weekmask по умолчанию Пн-Пт ('1111100')
        holidays_arr = np.array(
            [np.datetime64(h, 'D') for h in (holidays_list or [])],
            dtype='datetime64[D]'
        )
        ref = np.datetime64(ref_date, 'D')
        # roll='forward': если сам ref_date — выходной/праздник, сдвигаемся вперёд к
        # ближайшему рабочему дню, и только потом отступаем на один рабочий день назад.
        # Так для любого ref_date получаем последний рабочий день строго раньше него.
        prev = np.busday_offset(ref, -1, roll='forward', holidays=holidays_arr)
        return prev.astype('datetime64[D]').astype(object)

    # === ЛОГИКА ===
    def calculate_composition_uniform(self, pool, limit_hours, limit_zno=None, monitor_pct=None, pf_name='', add_log_func=None):
        current_hours = 0
        current_count = 0
        selected_indices = []

        # Ускорение: точечный доступ к Hours/Тип через dict вместо медленного pool.loc[idx, col]
        hours_map = pool['Hours'].to_dict()
        type_map = pool['Тип'].to_dict()

        if not limit_zno:
            groups = pool.groupby(['Тип', 'Маркер активности'])
            queues_data = []
            for (t_type, marker), group_df in groups:
                # Сортируем по приоритету активности (сначала техника с наименьшим приоритетом), затем по Is_Replacement, затем по возрасту
                sorted_group = group_df.sort_values(by=['Activity_Priority', 'Is_Replacement', 'Возраст, лет'], ascending=[True, False, False])
                q = deque(sorted_group.index.tolist())
                if q:
                    is_priority_group = sorted_group.iloc[0]['Is_Replacement']
                    queues_data.append({'queue': q, 'priority': is_priority_group, 'type': t_type, 'marker': marker})
            queues_data.sort(key=lambda x: not x['priority'])

            iteration_safety = 0
            while queues_data and iteration_safety < 5000:
                made_progress = False
                for item in queues_data[:]:
                    q = item['queue']
                    if not q:
                        queues_data.remove(item)
                        continue

                    cand_idx = q[0]
                    cand_hours = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]

                    if cand_hours == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен: нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: queues_data.remove(item)
                        continue

                    if current_hours + cand_hours <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_hours += cand_hours
                        q.popleft()
                        made_progress = True
                        if not q: queues_data.remove(item)
                    else:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен: превышен лимит часов (ПФ: {pf_name}, Тип: {cand_type})")

                if not made_progress: break
                iteration_safety += 1
        else:
            groups = pool.groupby(['Тип', 'Маркер активности'])
            all_queues = []
            for (t_type, marker), group_df in groups:
                # Сортируем по приоритету активности (сначала техника с наименьшим приоритетом), затем по Is_Replacement, затем по возрасту
                sorted_group = group_df.sort_values(by=['Activity_Priority', 'Is_Replacement', 'Возраст, лет'], ascending=[True, False, False])
                q = deque(sorted_group.index.tolist())
                if q:
                    is_priority_group = sorted_group.iloc[0]['Is_Replacement']
                    is_monitor = 'тр: монитор' in t_type.lower() or 'тр: монитор всп' in t_type.lower()
                    all_queues.append({
                        'queue': q,
                        'priority': is_priority_group,
                        'type': t_type,
                        'marker': marker,
                        'is_monitor': is_monitor
                    })

            all_queues.sort(key=lambda x: not x['priority'])

            monitor_queues = [x for x in all_queues if x['is_monitor']]
            other_queues = [x for x in all_queues if not x['is_monitor']]

            monitor_count_selected = 0
            other_count_selected = 0

            if monitor_pct and monitor_pct > 0:
                max_monitors = int(limit_zno * monitor_pct / 100)
                max_others = limit_zno - max_monitors
            else:
                max_monitors = 0
                max_others = limit_zno
                other_queues.extend(monitor_queues)
                monitor_queues = []

            iteration_safety = 0
            while monitor_queues and monitor_count_selected < max_monitors and iteration_safety < 5000:
                made_progress = False
                for item in monitor_queues[:]:
                    q = item['queue']
                    if not q:
                        monitor_queues.remove(item)
                        continue

                    cand_idx = q[0]
                    cand_hours = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]

                    if cand_hours == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Монитор): нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: monitor_queues.remove(item)
                        continue

                    if current_hours + cand_hours <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_hours += cand_hours
                        monitor_count_selected += 1
                        current_count += 1
                        q.popleft()
                        made_progress = True
                        if not q: monitor_queues.remove(item)
                        if monitor_count_selected >= max_monitors: break
                    else:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Монитор): превышен лимит часов (ПФ: {pf_name}, Тип: {cand_type})")

                if not made_progress: break
                iteration_safety += 1

            iteration_safety = 0
            while other_queues and other_count_selected < max_others and iteration_safety < 5000:
                made_progress = False
                for item in other_queues[:]:
                    q = item['queue']
                    if not q:
                        other_queues.remove(item)
                        continue

                    cand_idx = q[0]
                    cand_hours = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]

                    if cand_hours == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Другое): нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: other_queues.remove(item)
                        continue

                    if current_hours + cand_hours <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_hours += cand_hours
                        other_count_selected += 1
                        current_count += 1
                        q.popleft()
                        made_progress = True
                        if not q: other_queues.remove(item)
                    else:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Другое): превышен лимит часов (ПФ: {pf_name}, Тип: {cand_type})")

                if not made_progress: break
                iteration_safety += 1

        if selected_indices:
            result_slice = pool.loc[selected_indices]
            comp_series = result_slice['Тип'].value_counts()
            comp_str = ", ".join([f"{t}: {c}" for t, c in comp_series.items()])
        else: comp_str = "-"

        return selected_indices, round(current_hours, 2), comp_str

    # ============================================

    def run_logic(self, folder_path):
        dk_path = os.path.join(folder_path, "ДК.xlsx")
        ref_path = os.path.join(folder_path, "Справочник.xlsx")

        if not os.path.exists(dk_path) or not os.path.exists(ref_path):
            messagebox.showerror("Ошибка", "Файлы не найдены!")
            return

        self.log("Загрузка данных...")

        target_date = datetime.now().date()
        date_label = "Сегодня"
        if self.date_choice.get() == "tomorrow":
            target_date = (datetime.now() + timedelta(days=1)).date()
            date_label = "Завтра"

        self.log(f"Расчет выполняется на дату: {target_date} ({date_label})")

        self.progress['value'] = 10
        self.root.update_idletasks()

        try:
            xls = pd.ExcelFile(ref_path)

            # Ищем листы по точным названиям
            sheet_names = [name.strip() for name in xls.sheet_names]

            # Лист с мощностью (ПФ)
            if 'мощность' not in sheet_names:
                messagebox.showerror("Ошибка", "В справочнике не найден лист 'мощность'")
                return
            df_power = pd.read_excel(ref_path, sheet_name='мощность')

            # Лист с часами (КТР)
            if 'КТР' not in sheet_names:
                messagebox.showerror("Ошибка", "В справочнике не найден лист 'КТР'")
                return
            df_hours = pd.read_excel(ref_path, sheet_name='КТР')

            # Лист с приоритетами
            priority_dict = {}
            if 'Приоритет' in sheet_names:
                try:
                    df_priority = pd.read_excel(ref_path, sheet_name='Приоритет')
                    df_priority.columns = df_priority.columns.str.strip()
                    # Создаем словарь: активность -> приоритет
                    for idx, row in df_priority.iterrows():
                        activity = str(row.iloc[0]).strip() if len(row) > 0 else ''
                        priority = int(self.safe_float(row.iloc[1])) if len(row) > 1 else 999
                        if activity and activity.lower() not in ['nan', '']:
                            priority_dict[activity] = priority
                    self.log(f"Загружено {len(priority_dict)} активностей с приоритетами")
                except Exception as e:
                    self.log(f"Предупреждение: Не удалось загрузить лист 'Приоритет' из справочника: {e}")
            else:
                self.log("Предупреждение: В справочнике не найден лист 'Приоритет'")

            # Лист с праздниками / нерабочими днями (опционально).
            # Российские праздники нельзя вычислить алгоритмически (переносы задаются
            # указами), поэтому список ведётся вручную на отдельном листе справочника.
            holidays_list = []
            holiday_sheet = None
            for candidate in ['Праздники', 'праздники', 'Выходные', 'Нерабочие дни', 'Праздничные дни']:
                if candidate in sheet_names:
                    # Берём оригинальное (необрезанное) имя листа
                    holiday_sheet = xls.sheet_names[sheet_names.index(candidate)]
                    break
            if holiday_sheet is not None:
                try:
                    df_holidays = pd.read_excel(ref_path, sheet_name=holiday_sheet)
                    # Собираем даты из всех ячеек листа (поддерживаем любой формат столбцов)
                    for col in df_holidays.columns:
                        parsed = pd.to_datetime(df_holidays[col], errors='coerce', dayfirst=True)
                        for d in parsed.dropna():
                            holidays_list.append(d.date())
                    holidays_list = sorted(set(holidays_list))
                    self.log(f"Загружено праздничных/нерабочих дней: {len(holidays_list)}")
                except Exception as e:
                    self.log(f"Предупреждение: не удалось загрузить лист праздников '{holiday_sheet}': {e}")
            else:
                self.log("Лист с праздниками не найден — учитываются только выходные (сб, вс)")
        except Exception as e:
            messagebox.showerror("Ошибка", f"Справочник: {e}")
            return

        df_power.columns = df_power.columns.str.strip()
        df_hours.columns = df_hours.columns.str.strip()

        pf_power_dict = {str(row.iloc[0]).strip(): self.safe_float(row.iloc[1]) for idx, row in df_power.iterrows()}
        type_hours_dict = {str(row.iloc[0]).strip().lower(): self.safe_float(row.iloc[1]) for idx, row in df_hours.iterrows()}

        # === ЧТЕНИЕ КОЛОНОК ===
        pf_limit_zno_dict = {}
        pf_monitor_pct_dict = {}

        if 'Ограничение ЗНО в день' in df_power.columns:
            pf_limit_zno_dict = {str(row.iloc[0]).strip(): int(self.safe_float(row['Ограничение ЗНО в день'])) for idx, row in df_power.iterrows()}

        if 'Пропорции по мониторам' in df_power.columns:
            for idx, row in df_power.iterrows():
                val = self.safe_float(row['Пропорции по мониторам'])
                if val <= 1.0 and val > 0.0: val *= 100
                pf_monitor_pct_dict[str(row.iloc[0]).strip()] = val
        # ============================

        with warnings.catch_warnings():
            warnings.simplefilter("ignore")
            df_dk = pd.read_excel(dk_path)

        df_dk.columns = df_dk.columns.str.strip()
        df_dk.reset_index(drop=True, inplace=True)  # индекс 0..N-1 — нужно для быстрых списков Log/Status/Hours

        if 'Log' not in df_dk.columns: df_dk['Log'] = ""
        df_dk['Log'] = df_dk['Log'].fillna('')

        if 'Период' not in df_dk.columns:
            df_dk['Is_Excluded'] = False
        else:
            exclude_values = ['Проект']
            df_dk['Is_Excluded'] = df_dk['Период'].astype(str).str.strip().isin(exclude_values)
            df_dk.loc[df_dk['Is_Excluded'], 'Log'] = "Исключено: " + df_dk.loc[df_dk['Is_Excluded'], 'Период'].astype(str)
            self.log(f"Исключено строк из планирования (Период): {df_dk['Is_Excluded'].sum()}")

        if 'Маркер активности' not in df_dk.columns:
            messagebox.showerror("Ошибка", "В файле ДК не найден столбец 'Маркер активности'.")
            return

        df_dk['Status'] = "ОК"
        df_dk['Возраст, лет'] = pd.to_numeric(df_dk['Возраст, лет'], errors='coerce').fillna(0)
        df_dk['Is_Replacement'] = False
        df_dk['Hours'] = 0.0

        # === ШАГ: РАСЧЕТ ПРИОРИТЕТА ТЕХНИКИ ПО АКТИВНОСТЯМ ===
        if 'Домен' in df_dk.columns:
            def calculate_activity_priority(domains):
                if pd.isna(domains) or str(domains).strip() == '':
                    return 999  # Самый низкий приоритет для техники без активностей

                domain_list = [d.strip() for d in str(domains).split(',')]
                min_priority = 999
                for domain in domain_list:
                    if domain in priority_dict:
                        min_priority = min(min_priority, priority_dict[domain])
                return min_priority

            df_dk['Activity_Priority'] = df_dk['Домен'].apply(calculate_activity_priority)
            self.log("Рассчитаны приоритеты техники по активностям")
        else:
            df_dk['Activity_Priority'] = 999
            self.log("Столбец 'Домен' не найден, все техники имеют одинаковый приоритет")
        # ============================================

        # === ШАГ: АНАЛИЗ ФИО (ПОВТОРЯЮЩИЕСЯ ЗАПИСИ) ===
        if 'ФИО' in df_dk.columns:
            # Подсчет количества записей по каждому ФИО
            fio_counts = df_dk['ФИО'].value_counts()
            # ФИО с количеством >= 4 считаем как "всегда на рабочем месте"
            fio_permanent = set(fio_counts[fio_counts >= 4].index)
            df_dk['Is_FIO_Permanent'] = df_dk['ФИО'].isin(fio_permanent)
            self.log(f"Найдено {len(fio_permanent)} ФИО с 4+ записями (не учитываются отсутствия)")
        else:
            df_dk['Is_FIO_Permanent'] = False
            self.log("Столбец 'ФИО' не найден, проверка отсутствий для повторяющихся ФИО не выполняется")
        # ==============================================

        date_col_zno = 'ЗНО на Техрефреш: дата создания'
        if date_col_zno in df_dk.columns:
            with warnings.catch_warnings():
                warnings.simplefilter("ignore")
                df_dk[date_col_zno] = pd.to_datetime(df_dk[date_col_zno], errors='coerce').dt.tz_localize(None)

        # Ускорение: Log/Status/Hours держим в обычных списках Python и пишем в df_dk
        # один раз (массовые df.loc[idx, col]=... по 100к строк — главный тормоз цикла).
        log_list = df_dk['Log'].tolist()
        status_list = df_dk['Status'].tolist()
        hours_list = df_dk['Hours'].tolist()

        def add_log(idx, message, is_error=False):
            curr = str(log_list[idx])
            log_list[idx] = f"{curr}; {message}" if curr else message
            if is_error and status_list[idx] == 'ОК':
                status_list[idx] = "Ошибка"

        # Расчет часов и проверка ПФ
        for idx, row in df_dk.iterrows():
            dk_type = str(row['Тип']).strip().lower()
            if pd.isna(row['Тип']) or dk_type == '':
                add_log(idx, "Тип пустой", is_error=True)
            elif dk_type not in TYPE_MAPPING:
                add_log(idx, f"Тип '{row['Тип']}' не найден в правилах", is_error=True)
            else:
                ref_t = TYPE_MAPPING[dk_type]
                if ref_t.lower() not in type_hours_dict:
                    add_log(idx, f"Нет часов для типа '{ref_t}'", is_error=True)
                else:
                    hours_list[idx] = type_hours_dict[ref_t.lower()]

            pf_name = str(row['Адрес ПФ']).strip()
            if pd.isna(row['Адрес ПФ']) or pf_name == '':
                add_log(idx, "ПФ пустой", is_error=True)
            elif pf_name not in pf_power_dict:
                add_log(idx, f"ПФ '{pf_name}' не найден в справочнике. Установлен лимит 12ч.")

        # === ШАГ 1: ПРОВЕРКА ОТСУТСТВИЯ ===
        with warnings.catch_warnings():
            warnings.simplefilter("ignore")
            df_dk['ВК отсутствует с'] = pd.to_datetime(df_dk['ВК отсутствует с'], errors='coerce').dt.tz_localize(None)
            df_dk['ВК отсутствует по'] = pd.to_datetime(df_dk['ВК отсутствует по'], errors='coerce').dt.tz_localize(None)

        check_end_date = target_date + timedelta(days=5)
        for idx, row in df_dk.iterrows():
            s, e = row['ВК отсутствует с'], row['ВК отсутствует по']
            if pd.notna(s) and pd.notna(e):
                s_date = s.date()
                e_date = e.date()
                # Пропускаем проверку отсутствия для ФИО с 4+ записями
                if row['Is_FIO_Permanent']:
                    continue  # Такие записи всегда считаются на рабочем месте
                if (s_date <= check_end_date) and (e_date >= target_date):
                    add_log(idx, "ВК отсутствует")
        # ======================================

        # Переносим накопленные в списках значения обратно в df_dk перед векторными
        # операциями, которые читают эти столбцы (фильтр кандидатов по 'Log' и т.д.).
        df_dk['Log'] = log_list
        df_dk['Hours'] = hours_list

        self.log("Анализ отказников и избытка...")
        excess_by_pf = {}
        found_replacements = []  # Список словарей с данными о заменах

        def is_zno_empty(val):
            if pd.isna(val): return True
            return str(val).strip() in ['', '-']

        # === ШАГ 2: ПОИСК ЗАМЕН (НОВЫЕ УСЛОВИЯ) ===
        # Условия:
        # 1. ПФ пополнен (пустой/0)
        # 2. Не исключен
        # 3. ЗНО на Техрефреш (пустой) ИЛИ группировка "2.7 Перевыставить ЗНО"
        # 4. ВК не отсутствует
        # 5. Дата исполнения ЗНО на пополнение ПФ не более 2 месяцев от текущей даты
        #    (если ЗНО на пополнение ПФ есть и дата старше 2 месяцев - исключаем)
        # 6. Для отказников: дата исполнения ЗНО на Техрефреш должна быть строго
        #    раньше предыдущего рабочего дня (с учётом выходных и праздников).
        #    Если ЗНО закрылось в предыдущий рабочий день (или позже) — замену не ищем.

        # Проверка даты исполнения ЗНО на пополнение ПФ (не более 2 месяцев)
        date_col_replenishment = 'ЗНО на пополнение ПФ: дата исполнения'
        if date_col_replenishment in df_dk.columns:
            # Конвертируем даты
            with warnings.catch_warnings():
                warnings.simplefilter("ignore")
                df_dk[date_col_replenishment] = pd.to_datetime(df_dk[date_col_replenishment], errors='coerce').dt.tz_localize(None)
            # Вычисляем дату 2 месяцев назад от целевой даты
            two_months_ago = target_date - timedelta(days=60)
            # Создаем маску: True если дата исполнения >= 2 месяцев назад ИЛИ ЗНО на пополнение ПФ пустой
            df_dk['Is_Replenishment_Valid'] = (
                                                      df_dk[date_col_replenishment].dt.date >= two_months_ago
                                              ) | df_dk['ЗНО на пополнение ПФ'].apply(is_zno_empty)
            self.log(f"Проверка даты исполнения ЗНО на пополнение ПФ: дата не более 2 месяцев от {target_date}")
        else:
            df_dk['Is_Replenishment_Valid'] = True
            self.log(f"Столбец '{date_col_replenishment}' не найден, проверка даты не выполняется")

        candidates_df = df_dk[
            (
                    (df_dk['ПФ пополнен'].isna()) | (df_dk['ПФ пополнен'] == 0) |
                    (df_dk['ПФ пополнен'].astype(str).str.strip() == '0') |
                    (df_dk['ПФ пополнен'].astype(str).str.strip() == '')
            ) &
            (~df_dk['Is_Excluded']) &
            (
                    (df_dk['ЗНО на Техрефреш'].apply(is_zno_empty)) |
                    (df_dk['Результат Техрефреш: группировка'].astype(str).str.strip().str.contains(r'2\.7.*Перевыставить', na=False))
            ) &
            (~df_dk['Log'].str.contains("ВК отсутствует")) &
            (df_dk['Is_Replenishment_Valid'])
            ].sort_values(by='Возраст, лет', ascending=False)

        grouped_candidates = candidates_df.groupby(['Адрес ПФ', 'Тип', 'Маркер активности']).groups

        refused_rows = df_dk[
            df_dk['Результат Техрефреш: группировка'].astype(str).str.startswith(('2.1', '2.2')) &
            (~df_dk['Is_Excluded'])
            ]

        # Проверка даты исполнения ЗНО на Техрефреш для отказников:
        # замена ищется, только если дата исполнения строго РАНЬШЕ предыдущего
        # рабочего дня (предыдущий рабочий день и позже считаем "слишком свежим").
        date_col_zno_execution = 'ЗНО на Техрефреш: дата исполнения'
        prev_working_day = None
        if date_col_zno_execution in df_dk.columns:
            with warnings.catch_warnings():
                warnings.simplefilter("ignore")
                df_dk[date_col_zno_execution] = pd.to_datetime(df_dk[date_col_zno_execution], errors='coerce').dt.tz_localize(None)
            prev_working_day = self.get_previous_working_day(target_date, holidays_list)
            self.log(f"Предыдущий рабочий день от {target_date.strftime('%d.%m.%Y')}: {prev_working_day.strftime('%d.%m.%Y')}. "
                     f"Замена ищется только если дата исполнения ЗНО < {prev_working_day.strftime('%d.%m.%Y')}")

        # Словарь для хранения дат ЗНО на пополнение ПФ по номеру ЗНО
        zno_replenishment_dates = {}
        date_col_replenishment = 'ЗНО на пополнение ПФ: дата исполнения'
        zno_col = 'ЗНО на пополнение ПФ'
        if date_col_replenishment in df_dk.columns and zno_col in df_dk.columns:
            # Создаем словарь: номер ЗНО -> дата исполнения (векторно, без df.loc по каждой строке)
            for zno_val, zno_date in zip(df_dk[zno_col], df_dk[date_col_replenishment]):
                zno_num = str(zno_val).strip() if pd.notna(zno_val) else ''
                if zno_num and zno_num != '-' and pd.notna(zno_date):
                    zno_date_parsed = pd.to_datetime(zno_date).replace(tzinfo=None)
                    if hasattr(zno_date_parsed, 'date'):
                        zno_replenishment_dates[zno_num] = zno_date_parsed.date()

        for idx, refused_row in refused_rows.iterrows():
            pf, tp = refused_row['Адрес ПФ'], refused_row['Тип']

            is_pf_replenished = (refused_row['ПФ пополнен'] == 1 or str(refused_row['ПФ пополнен']).strip() == '1')

            if not is_pf_replenished:
                continue

            # Проверка даты исполнения ЗНО на Техрефреш для отказников.
            # Замена не ищется, если ЗНО закрылось в предыдущий рабочий день или позже.
            if prev_working_day is not None:
                zno_exec_date = df_dk.loc[idx, date_col_zno_execution]
                if pd.notna(zno_exec_date):
                    exec_date = pd.to_datetime(zno_exec_date).replace(tzinfo=None).date()
                    # exec_date >= предыдущего рабочего дня → слишком свежий, пропускаем
                    if exec_date >= prev_working_day:
                        add_log(idx, f"ЗНО на Техрефреш слишком свежий ({exec_date.strftime('%d.%m.%Y')}), "
                                     f"не раньше предыдущего рабочего дня ({prev_working_day.strftime('%d.%m.%Y')}), замена не требуется")
                        excess_by_pf[pf] = excess_by_pf.get(pf, 0) + 1
                        continue

            # Проверка даты исполнения ЗНО на пополнение ПФ для отказника
            # Приоритет 1: ЗНО на пополнение ПФ: дата исполнения (если номер ЗНО >= 13 символов)
            # Приоритет 2: ЗНО на пополнение ПФ: дата создания (если номер ЗНО >= 13 символов)
            # Приоритет 3: Доп. параметр 2 (номер ЗНО) -> поиск даты в словаре (если номер >= 13 символов)
            date_to_check = None
            correct_zno = ''  # Корректный номер ЗНО (13+ символов)

            # Получаем номер ЗНО из основного поля
            refusal_zno_field = refused_row.get('ЗНО на пополнение ПФ', '')
            zno_from_field = str(refusal_zno_field).strip() if pd.notna(refusal_zno_field) else ''

            # Получаем номер из Доп. параметр 2
            zno_ref = str(refused_row.get('Доп. параметр 2', '')).strip() if pd.notna(refused_row.get('Доп. параметр 2', '')) else ''

            # Если номер в основном поле >= 13 символов
            if len(zno_from_field) >= 13:
                correct_zno = zno_from_field
                # Проверяем дату исполнения
                if date_col_replenishment in df_dk.columns:
                    replenishment_date = df_dk.loc[idx, date_col_replenishment]
                    if pd.notna(replenishment_date):
                        replenishment_dt = pd.to_datetime(replenishment_date, errors='coerce').replace(tzinfo=None)
                        if pd.notna(replenishment_dt) and hasattr(replenishment_dt, 'date'):
                            date_to_check = replenishment_dt.date()

                # Если дата не найдена, проверяем дату создания
                if date_to_check is None:
                    date_col_create = 'ЗНО на пополнение ПФ: дата создания'
                    if date_col_create in df_dk.columns:
                        create_date = df_dk.loc[idx, date_col_create]
                        if pd.notna(create_date):
                            create_date_str = str(create_date).strip()
                            if create_date_str and create_date_str != '-':
                                create_dt = pd.to_datetime(create_date, errors='coerce').replace(tzinfo=None)
                                if pd.notna(create_dt) and hasattr(create_dt, 'date'):
                                    date_to_check = create_dt.date()

            # Если дата не найдена и есть корректный номер в Доп. параметр 2 (>= 13 символов)
            if date_to_check is None and len(zno_ref) >= 13:
                correct_zno = zno_ref  # Используем номер из Доп. параметр 2
                # Ищем этот номер в столбце "ЗНО на пополнение ПФ"
                if zno_ref in zno_replenishment_dates:
                    date_to_check = zno_replenishment_dates[zno_ref]
                else:
                    # ЗНО не найдено в файле
                    add_log(idx, f"ЗНО '{zno_ref}' из Доп. параметр 2 не найдено в столбце 'ЗНО на пополнение ПФ'")
                    excess_by_pf[pf] = excess_by_pf.get(pf, 0) + 1
                    continue

            # Если дата не найдена, пропускаем отказника
            if date_to_check is None:
                add_log(idx, f"Нет даты исполнения ЗНО на пополнение ПФ")
                excess_by_pf[pf] = excess_by_pf.get(pf, 0) + 1
                continue

            # Проверяем - не старше ли 2 месяцев от текущей даты
            two_months_from_now = target_date + timedelta(days=60)  # 2 месяца вперед
            if date_to_check > two_months_from_now:
                add_log(idx, f"ЗНО на пополнение ПФ слишком поздний ({date_to_check.strftime('%d.%m.%Y')}), замена не требуется")
                excess_by_pf[pf] = excess_by_pf.get(pf, 0) + 1
                continue

            marker = refused_row['Маркер активности']
            key = (pf, tp, marker)

            found = False
            if key in grouped_candidates:
                indices = grouped_candidates[key]
                if len(indices) > 0:
                    match_idx = indices[0]

                    refusal_sn = str(refused_row.get('Серийный номер', 'N/A')).strip()
                    candidate_sn = str(df_dk.loc[match_idx, 'Серийный номер']).strip()

                    df_dk.loc[match_idx, 'Is_Replacement'] = True
                    add_log(match_idx, f"ЗАМЕНА ДЛЯ ОТКАЗНИКА (SN: {refusal_sn})")
                    add_log(idx, f"ЗАМЕНА НАЙДЕНА (Кандидат SN: {candidate_sn})")

                    # Сохраняем данные о замене
                    # refusal_zno должно содержать 13+ символов (уже проверено выше)
                    found_replacements.append({
                        'candidate_idx': match_idx,
                        'refusal_sn': refusal_sn,
                        'refusal_zno': correct_zno  # Используем корректный номер ЗНО (13+ символов)
                    })

                    grouped_candidates[key] = indices[1:]
                    found = True

            if not found:
                add_log(idx, "ИЗБЫТОК: Нет замены")
                excess_by_pf[pf] = excess_by_pf.get(pf, 0) + 1
        # ======================================

        # ШАГ 3: Формирование пула планирования
        selected_indices = []
        for idx, row in df_dk.iterrows():
            pf_name = str(row['Адрес ПФ']).strip() if pd.notna(row['Адрес ПФ']) else 'N/A'

            # Пропускаем исключенные
            if row['Is_Excluded']:
                add_log(idx, f"Исключено: по периоду (ПФ: {pf_name})")
                continue
            # Пропускаем с ошибками
            if status_list[idx] == "Ошибка":
                add_log(idx, f"Ошибка в данных (ПФ: {pf_name})")
                continue
            # Проверка отсутствия ВК (для обычных записей)
            if "ВК отсутствует" in log_list[idx]:
                add_log(idx, f"ВК отсутствует (ПФ: {pf_name})")
                continue

            pf_pop = row['ПФ пополнен']
            is_rep = row['Is_Replacement']
            is_pf_rep = (pf_pop == 1 or str(pf_pop).strip() == '1')
            group_result = str(row.get('Результат Техрефреш: группировка', '')).strip()
            is_transferred_zno = '2.7' in group_result and 'Перевыставить' in group_result

            # Проверка ПФ пополнен или замена
            if not is_pf_rep and not is_rep:
                add_log(idx, f"ПФ не пополнен и не замена (ПФ: {pf_name})")
                continue
            # Для обычных записей: проверка ЗНО на Техрефреш
            # Для группировки 2.7: даже если есть ЗНО на техрефреш - включаем в пул
            if not is_transferred_zno and not is_zno_empty(row['ЗНО на Техрефреш']):
                add_log(idx, f"Есть ЗНО на Техрефреш (ПФ: {pf_name}, ЗНО: {str(row['ЗНО на Техрефреш']).strip()})")
                continue
            # Проверка даты исполнения ЗНО на пополнение ПФ (для обычных записей, не для группировки 2.7)
            if not is_transferred_zno:
                date_col_replenishment = 'ЗНО на пополнение ПФ: дата исполнения'
                if date_col_replenishment in df_dk.columns:
                    if pd.notna(row[date_col_replenishment]):
                        replenishment_date = pd.to_datetime(row[date_col_replenishment]).replace(tzinfo=None).date()
                        two_months_ago = target_date - timedelta(days=60)
                        if replenishment_date < two_months_ago:
                            add_log(idx, f"ЗНО на пополнение ПФ старше 2 месяцев ({replenishment_date.strftime('%d.%m.%Y')}) (ПФ: {pf_name})")
                            continue

            selected_indices.append(idx)
            if is_transferred_zno:
                add_log(idx, f">>> ВЫБРАН В ПУЛ (ПФ: {pf_name}, Группировка: {group_result}, ПЕРЕВЫСТАВЛЕНИЕ ЗНО)")
            else:
                add_log(idx, f">>> ВЫБРАН В ПУЛ (ПФ: {pf_name}, Группировка: {group_result})")

        valid_pool = df_dk.loc[selected_indices].copy()

        final_indices = []
        stats_table = []
        plan_distribution = {}

        final_adjusted_indices = []
        adjusted_stats_table = []

        self.log("Расчет статистики отказов (ПФ + Тип)...")

        # Расчет периода: последние 30 дней от текущей даты
        start_date_30days = target_date - timedelta(days=30)
        end_date = target_date

        self.log(f"Период для аналитики отказов: {start_date_30days.strftime('%d.%m.%Y')} - {end_date.strftime('%d.%m.%Y')} (последние 30 дней)")

        closed_pool = df_dk[df_dk['ЗНО на Техрефреш'].notna() & (df_dk['ЗНО на Техрефреш'].astype(str).str.strip() != '-')].copy()

        if date_col_zno in closed_pool.columns:
            closed_pool = closed_pool[
                (closed_pool[date_col_zno].dt.date >= start_date_30days) &
                (closed_pool[date_col_zno].dt.date <= end_date)
                ]
        else:
            self.log("Предупреждение: Столбец даты создания не найден, аналитика считается за все время.")

        all_bad_results = [
            '2.2. Пользователь отказался от замены насовсем',
            '2.8. Не соответствует критериям техрефреша',
            '2.1. Пользователь или АРМ не найден',
            '1.2. Техника заменена раннее',
            '2.3. ВК отказался от проведения работ',
            '4.1. Оборудование не найдено',
            '2.3. Пользователь перенес работы на другое время',
            '2.4. Отсутствует оборудование на ПФ'
        ]

        pf_type_fail_rates = {}
        failure_stats = []

        for (pf, tp), group in closed_pool.groupby(['Адрес ПФ', 'Тип']):
            total = len(group)
            fails = len(group[group['Результат Техрефреш: группировка'].isin(all_bad_results)])
            if total > 0:
                rate = round((fails / total) * 100, 1)
                failure_stats.append({'pf': pf, 'type': tp, 'total': total, 'fails': fails, 'rate': rate})
                pf_type_fail_rates[(pf, tp)] = rate

        unique_pfs = sorted(valid_pool['Адрес ПФ'].unique(), key=str)

        for pf in unique_pfs:
            if pd.isna(pf): continue

            limit = pf_power_dict.get(pf, 12)
            limit_zno = pf_limit_zno_dict.get(pf)
            monitor_pct = pf_monitor_pct_dict.get(pf, 0.0)

            if limit_zno:
                self.log(f"PF: {pf} | Limit: {limit_zno} | Monitor %: {monitor_pct}")

            pf_pool = valid_pool[valid_pool['Адрес ПФ'] == pf].copy()
            if pf_pool.empty: continue

            # Стандартный план
            idx_all, hours_all, str_all = self.calculate_composition_uniform(
                pf_pool, limit, limit_zno=limit_zno, monitor_pct=monitor_pct, pf_name=pf, add_log_func=add_log
            )

            for i in idx_all: add_log(i, f">>> ВЫБРАН (ПФ: {pf}, Группа: {str_all})")
            final_indices.extend(idx_all)

            stats_table.append({
                'pf': pf, 'count': len(idx_all), 'hours': hours_all,
                'excess': excess_by_pf.get(pf, 0), 'comp_all': str_all, 'comp_plan': str_all
            })

            # Логирование записей, которые были в пуле, но не попали в план
            if len(pf_pool) > len(idx_all):
                not_selected = pf_pool[~pf_pool.index.isin(idx_all)]
                for idx, row in not_selected.iterrows():
                    group_result = str(row.get('Результат Техрефреш: группировка', '')).strip()
                    is_transferred_zno = '2.7' in group_result and 'Перевыставить' in group_result
                    if is_transferred_zno:
                        add_log(idx, f"НЕ ВЫБРАН В ПЛАН (ПФ: {pf}, есть в пуле, но лимит часов/ЗНО) (Группировка: {group_result})")
                    else:
                        add_log(idx, f"НЕ ВЫБРАН В ПЛАН (ПФ: {pf}, есть в пуле, но лимит часов/ЗНО)")

            # Подсчет записей с группировкой 2.7 отдельно
            transferred_count = 0
            if idx_all:
                res_slice = df_dk.loc[idx_all]
                transferred_count = len(res_slice[res_slice['Результат Техрефреш: группировка'].astype(str).str.contains(r'2\.7.*Перевыставить', na=False)])
            if transferred_count > 0:
                stats_table[-1]['comp_all'] = f"{str_all} | 2.7: {transferred_count}" if str_all else f"2.7: {transferred_count}"

            res_slice = df_dk.loc[idx_all]
            for t in res_slice['Тип']: plan_distribution[t] = plan_distribution.get(t, 0) + 1

            # Вероятностный план
            idx_adj, std_h_adj, eff_h_adj, str_adj, avg_fail_rate = self.calculate_adjusted_composition_uniform(
                pf_pool, limit, pf_type_fail_rates, pf, limit_zno=limit_zno, monitor_pct=monitor_pct, add_log_func=add_log
            )

            for i in idx_adj: add_log(i, f">>> ВЫБРАН В ВЕР-НЫЙ ПЛАН (ПФ: {pf}, Группа: {str_adj})")
            final_adjusted_indices.extend(idx_adj)

            adjusted_stats_table.append({
                'pf': pf,
                'count': len(idx_adj),
                'hours_std': std_h_adj,
                'hours_eff': eff_h_adj,
                'fail_rate_used': f"{avg_fail_rate}%",
                'comp': str_adj
            })

        # Переносим финальные Log/Status обратно в df_dk для листов "Ошибки и Пропуски" и "Debug Log".
        df_dk['Log'] = log_list
        df_dk['Status'] = status_list

        total_zno_std = sum(d['count'] for d in stats_table)
        total_hours_std = sum(d['hours'] for d in stats_table)
        total_excess = sum(d['excess'] for d in stats_table)
        self.lbl_total_plan.config(text=f"ИТОГО: ЗНО: {total_zno_std} | Часов: {total_hours_std} | Избыток: {total_excess}")

        total_zno_adj = sum(d['count'] for d in adjusted_stats_table)
        total_hours_std_adj = sum(d['hours_std'] for d in adjusted_stats_table)
        total_hours_eff_adj = sum(d['hours_eff'] for d in adjusted_stats_table)
        self.lbl_total_adj.config(text=f"ИТОГО: ЗНО: {total_zno_adj} | Станд.Часов: {total_hours_std_adj} | Эфф.Часов: {total_hours_eff_adj}")

        self.found_replacements_data_store = []
        self.plan_data_store = stats_table
        self.fail_data_store = sorted(failure_stats, key=lambda x: x['rate'], reverse=True)
        self.adjusted_plan_data_store = adjusted_stats_table

        self.entry_search_plan.delete(0, tk.END)
        self.entry_search_fail.delete(0, tk.END)
        self.entry_search_adj.delete(0, tk.END)

        self.search_plan()
        self.search_failures()
        self.search_adjusted()

        self.progress['value'] = 90
        timestamp = datetime.now().strftime("%d.%m.%Y")
        output_path = os.path.join(folder_path, f"План_ЗНО_{timestamp}.xlsx")

        def clean_dates(df):
            for col in df.columns:
                if pd.api.types.is_datetime64_any_dtype(df[col]):
                    if hasattr(df[col].dtype, 'tz') and df[col].dtype.tz is not None:
                        df[col] = df[col].dt.tz_localize(None)
            return df

        writer = pd.ExcelWriter(output_path, engine='openpyxl')

        if final_indices:
            result_df = df_dk.loc[final_indices].copy()
            result_df['Причина'] = result_df.apply(
                lambda x: 'Замена отказника' if x['Is_Replacement'] else (
                    'Плановый рефреш (Перевыставка)' if '2.7' in str(x.get('Результат Техрефреш: группировка', '')).strip() and 'Перевыставить' in str(x.get('Результат Техрефреш: группировка', '')).strip() else 'Плановый рефреш'
                ), axis=1
            )
            result_df = clean_dates(result_df)
            result_df = self.add_semicolon_to_serial(result_df)
            result_df.to_excel(writer, sheet_name='План ЗНО (Стандарт)', index=False)
        else:
            pd.DataFrame().to_excel(writer, sheet_name='План ЗНО (Стандарт)', index=False)

        pd.DataFrame(stats_table).to_excel(writer, sheet_name='Сводный план (Стандарт)', index=False)

        if final_adjusted_indices:
            result_adj_df = df_dk.loc[final_adjusted_indices].copy()
            result_adj_df['Причина'] = result_adj_df.apply(
                lambda x: 'Замена отказника' if x['Is_Replacement'] else (
                    'Плановый рефреш (Перевыставка)' if '2.7' in str(x.get('Результат Техрефреш: группировка', '')).strip() and 'Перевыставить' in str(x.get('Результат Техрефреш: группировка', '')).strip() else 'Плановый рефреш'
                ), axis=1
            )
            result_adj_df = clean_dates(result_adj_df)
            result_adj_df = self.add_semicolon_to_serial(result_adj_df)
            result_adj_df.to_excel(writer, sheet_name='План ЗНО (Вероятн)', index=False)
        else:
            pd.DataFrame().to_excel(writer, sheet_name='План ЗНО (Вероятн)', index=False)

        pd.DataFrame(adjusted_stats_table).to_excel(writer, sheet_name='Сводный план (Вероятн)', index=False)

        if found_replacements:
            # Создаем список записей для листа "Найденные замены"
            replacements_list = []
            for rep in found_replacements:
                idx = rep['candidate_idx']
                row = df_dk.loc[idx]
                replacements_list.append({
                    'ПФ': str(row['Адрес ПФ']).strip() if pd.notna(row['Адрес ПФ']) else '-',
                    'Тип': str(row['Тип']).strip(),
                    'Серийный номер': str(row['Серийный номер']).strip() if pd.notna(row['Серийный номер']) else '-',
                    'Серийник Отказника': rep['refusal_sn'],
                    'ЗНО ПФ отказника': rep['refusal_zno'],
                    'Вероятн. план': '✅ Да' if idx in final_adjusted_indices else '❌ Нет'
                })
            replacements_df = pd.DataFrame(replacements_list)
            replacements_df = clean_dates(replacements_df)
            replacements_df = self.add_semicolon_to_serial(replacements_df)
            replacements_df.to_excel(writer, sheet_name='Найденные Замены', index=False)
        else:
            pd.DataFrame().to_excel(writer, sheet_name='Найденные Замены', index=False)

        skipped_df = df_dk[
            (df_dk['Status'] == "Ошибка") |
            (df_dk['Log'].str.contains("ИЗБЫТОК")) |
            (df_dk['Log'].str.contains("ВК отсутствует")) |
            (df_dk['Is_Excluded']) |
            (df_dk['Log'].str.contains("ПФ не пополнен")) |
            ((df_dk['Log'].str.contains("Есть ЗНО на Техрефреш")) & (~df_dk['Результат Техрефреш: группировка'].astype(str).str.contains(r'2\.7.*Перевыставить', na=False)))
            ].copy()

        if not skipped_df.empty:
            skipped_df = clean_dates(skipped_df)
            skipped_df = self.add_semicolon_to_serial(skipped_df)
            skipped_df.to_excel(writer, sheet_name='Ошибки и Пропуски', index=False)
        else:
            pd.DataFrame().to_excel(writer, sheet_name='Ошибки и Пропуски', index=False)

        df_debug = clean_dates(df_dk.copy())
        
        df_debug.to_excel(writer, sheet_name='Debug Log', index=False)
        writer.close()

        self.create_excel_dashboard(df_dk, output_path)
        self.progress['value'] = 100
        messagebox.showinfo("Успех", f"Готово!\nПлан сформирован на: {date_label} ({target_date})\nФайл сохранен:\n{output_path}")

    # === ФУНКЦИЯ ВЕРОЯТНОСТЕЙ ===
    def calculate_adjusted_composition_uniform(self, pool, limit_hours, fail_lookup_dict, pf_name, limit_zno=None, monitor_pct=None, add_log_func=None):
        current_eff_hours = 0
        current_std_hours = 0
        current_count = 0
        selected_indices = []

        # Ускорение: точечный доступ к Hours/Тип через dict вместо медленного pool.loc[idx, col]
        hours_map = pool['Hours'].to_dict()
        type_map = pool['Тип'].to_dict()

        total_rate_sum = 0.0
        total_items_for_rate = 0

        if not limit_zno:
            groups = pool.groupby(['Тип', 'Маркер активности'])
            queues_data = []
            for (t_type, marker), group_df in groups:
                # Сортируем по приоритету активности (сначала техника с наименьшим приоритетом), затем по Is_Replacement, затем по возрасту
                sorted_group = group_df.sort_values(by=['Activity_Priority', 'Is_Replacement', 'Возраст, лет'], ascending=[True, False, False])
                q = deque(sorted_group.index.tolist())
                if q:
                    is_priority_group = sorted_group.iloc[0]['Is_Replacement']
                    queues_data.append({'queue': q, 'priority': is_priority_group, 'type': t_type, 'marker': marker})
            queues_data.sort(key=lambda x: not x['priority'])

            iteration_safety = 0
            while queues_data and iteration_safety < 5000:
                made_progress = False
                for item in queues_data[:]:
                    q = item['queue']
                    if not q:
                        queues_data.remove(item)
                        continue

                    cand_idx = q[0]
                    std_h = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]
                    if std_h == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Вероятн): нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: queues_data.remove(item)
                        continue

                    t_type = item['type']
                    key = (pf_name, t_type)
                    rate = fail_lookup_dict.get(key, 0) / 100.0
                    eff_h = (std_h * (1 - rate)) + (FAILED_TIME_HOURS * rate)

                    if current_eff_hours + eff_h <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_eff_hours += eff_h
                        current_std_hours += std_h
                        total_rate_sum += (rate * 100)
                        total_items_for_rate += 1
                        q.popleft()
                        made_progress = True
                        if not q: queues_data.remove(item)
                    else:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Вероятн): превышен лимит часов (ПФ: {pf_name}, Тип: {cand_type})")

                if not made_progress: break
                iteration_safety += 1
        else:
            groups = pool.groupby(['Тип', 'Маркер активности'])
            all_queues = []
            for (t_type, marker), group_df in groups:
                # Сортируем по приоритету активности (сначала техника с наименьшим приоритетом), затем по Is_Replacement, затем по возрасту
                sorted_group = group_df.sort_values(by=['Activity_Priority', 'Is_Replacement', 'Возраст, лет'], ascending=[True, False, False])
                q = deque(sorted_group.index.tolist())
                if q:
                    is_priority_group = sorted_group.iloc[0]['Is_Replacement']
                    is_monitor = 'тр: монитор' in t_type.lower() or 'тр: монитор всп' in t_type.lower()
                    all_queues.append({
                        'queue': q,
                        'priority': is_priority_group,
                        'type': t_type,
                        'marker': marker,
                        'is_monitor': is_monitor
                    })
            all_queues.sort(key=lambda x: not x['priority'])

            monitor_queues = [x for x in all_queues if x['is_monitor']]
            other_queues = [x for x in all_queues if not x['is_monitor']]

            monitor_count_selected = 0
            other_count_selected = 0

            if monitor_pct and monitor_pct > 0:
                max_monitors = int(limit_zno * monitor_pct / 100)
                max_others = limit_zno - max_monitors
            else:
                max_monitors = 0
                max_others = limit_zno
                other_queues.extend(monitor_queues)
                monitor_queues = []

            iteration_safety = 0
            while monitor_queues and monitor_count_selected < max_monitors and iteration_safety < 5000:
                made_progress = False
                for item in monitor_queues[:]:
                    q = item['queue']
                    if not q:
                        monitor_queues.remove(item)
                        continue

                    cand_idx = q[0]
                    std_h = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]
                    if std_h == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Вероятн Монитор): нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: monitor_queues.remove(item)
                        continue

                    t_type = item['type']
                    key = (pf_name, t_type)
                    rate = fail_lookup_dict.get(key, 0) / 100.0
                    eff_h = (std_h * (1 - rate)) + (FAILED_TIME_HOURS * rate)

                    if current_eff_hours + eff_h <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_eff_hours += eff_h
                        current_std_hours += std_h
                        monitor_count_selected += 1
                        current_count += 1
                        total_rate_sum += (rate * 100)
                        total_items_for_rate += 1
                        q.popleft()
                        made_progress = True
                        if not q: monitor_queues.remove(item)
                        if monitor_count_selected >= max_monitors: break

                if not made_progress: break
                iteration_safety += 1

            iteration_safety = 0
            while other_queues and other_count_selected < max_others and iteration_safety < 5000:
                made_progress = False
                for item in other_queues[:]:
                    q = item['queue']
                    if not q:
                        other_queues.remove(item)
                        continue

                    cand_idx = q[0]
                    std_h = hours_map[cand_idx]
                    cand_type = type_map[cand_idx]
                    if std_h == 0:
                        if add_log_func:
                            add_log_func(cand_idx, f"Пропущен (Вероятн Другое): нулевые часы (ПФ: {pf_name})")
                        q.popleft()
                        if not q: other_queues.remove(item)
                        continue

                    t_type = item['type']
                    key = (pf_name, t_type)
                    rate = fail_lookup_dict.get(key, 0) / 100.0
                    eff_h = (std_h * (1 - rate)) + (FAILED_TIME_HOURS * rate)

                    if current_eff_hours + eff_h <= limit_hours + 0.5:
                        selected_indices.append(cand_idx)
                        current_eff_hours += eff_h
                        current_std_hours += std_h
                        other_count_selected += 1
                        current_count += 1
                        total_rate_sum += (rate * 100)
                        total_items_for_rate += 1
                        q.popleft()
                        made_progress = True
                        if not q: other_queues.remove(item)

                if not made_progress: break
                iteration_safety += 1

        if selected_indices:
            result_slice = pool.loc[selected_indices]
            comp_series = result_slice['Тип'].value_counts()
            comp_str = ", ".join([f"{t}: {c}" for t, c in comp_series.items()])
        else: comp_str = "-"

        avg_fail_rate = round(total_rate_sum / total_items_for_rate, 1) if total_items_for_rate > 0 else 0.0

        return selected_indices, round(current_std_hours, 2), round(current_eff_hours, 2), comp_str, avg_fail_rate

    def add_semicolon_to_serial(self, df, col_name='Серийный номер'):
        if col_name in df.columns and len(df) > 0:
            indices_to_change = df.iloc[:-1].index
            df.loc[indices_to_change, col_name] = df.loc[indices_to_change, col_name].astype(str) + ";"
        return df

    def create_excel_dashboard(self, df, output_path):
        try:
            from openpyxl import load_workbook, Workbook
